# Polymarket CLOB API
CLOB_API_URL=https://clob.polymarket.com
PRIVATE_KEY=0xYOUR_POLYGON_PRIVATE_KEY_HERE

# Category filter (true = only sports, false = all markets)
FILTER_CATEGORIES=true

# Strategy: Underdog Bounce
MIN_PRICE=0.05
MAX_PRICE=0.25
MIN_LIQUIDITY=10000
BOUNCE_TARGET=0.08
STOP_LOSS=0.20
ORDER_FRAGMENTS=15
SCAN_INTERVAL=8

# Risk
MAX_POSITION_USD=50
MAX_OPEN_POSITIONS=5

# Logging
LOG_FILE=polybot.log
LOG_LEVEL=INFO
